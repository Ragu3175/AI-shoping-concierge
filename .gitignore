# ==========================================
# Comprehensive .gitignore for AI Shopping Concierge
# (Covers Frontend React Native/Expo & Python Backend)
# ==========================================

# 1. Environment Variables & Secrets
.env
.env.*
!.env.example
*.env
*.pem
*.key

# 2. Node.js & React Native / Expo Dependencies & Builds
node_modules/
.expo/
dist/
web-build/
expo-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.metro-health-check*
*.tsbuildinfo

# 3. Native Builds (iOS / Android generated files)
.kotlin/
*.jks
*.p8
*.p12
*.mobileprovision
/ios/
/android/

# 4. Python & Virtual Environments
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# 5. Python Testing, Coverage & Cache
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# 6. Database Files, Datasets, Vector Stores & Uploads
*.sqlite
*.sqlite3
*.db
backend/uploads/*
!backend/uploads/.gitkeep

# Raw dataset (44k+ images, regenerable/re-downloadable, don't commit)
backend/data/raw/images/
backend/data/raw/*.csv



# 7. Editor & IDE Settings
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.claude/

# 8. Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
